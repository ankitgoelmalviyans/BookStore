{
  "Otel": {
    "ServiceName": "BookStore.NotificationService",
    "OtlpEndpoint": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "BookStore.NotificationService"
    }
  },
  "Notifications": {
    "Enabled": false
  },
  "AzureServiceBus": {
    "ConnectionString": "",
    "OrderTopic": "order-events",
    "OrderSubscription": "notification-order-subscription",
    "PaymentTopic": "payment-events",
    "PaymentSubscription": "notification-payment-subscription"
  },
  "AllowedHosts": "*"
}

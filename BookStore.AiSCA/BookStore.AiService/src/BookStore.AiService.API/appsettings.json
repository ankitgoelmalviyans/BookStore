{
  "Otel": {
    "ServiceName": "BookStore.AiService",
    "OtlpEndpoint": ""
  },
  "Jwt": {
    "Issuer": "BookStore.Identity",
    "Audience": "BookStore.Services",
    "Key": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ],
    "Properties": {
      "Application": "BookStore.AiService"
    }
  },
  "Ai": {
    "IngestionEnabled": false
  },
  "AzureServiceBus": {
    "ConnectionString": "",
    "ProductTopicName": "product-events",
    "ProductSubscriptionName": "ai-product-subscription"
  },
  "UseCosmosDb": true,
  "CosmosDb": {
    "CosmosEndpoint": "",
    "AccountKey": "",
    "DatabaseName": "BookStoreDB",
    "EmbeddingsContainerName": "BookEmbeddings",
    "InboxContainerName": "ProcessedMessages"
  },
  "AzureOpenAI": {
    "Endpoint": "",
    "Key": "",
    "EmbeddingDeployment": "text-embedding-3-small",
    "ChatDeployment": "gpt-4o-mini"
  },
  "AllowedOrigins": [
    "http://localhost:4200"
  ],
  "AllowedHosts": "*"
}
